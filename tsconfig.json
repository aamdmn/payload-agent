{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ES2022"],
    "rootDir": "./",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "emitDeclarationOnly": true,
    "target": "ES2022",
    "composite": true
  },
  "include": ["./src/**/*.ts"]
}
