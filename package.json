{
  "name": "payload-agent",
  "version": "0.2.0",
  "description": "PayloadCMS CLI for AI agents and humans. Simple, direct access to your CMS data.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "payload-agent": "./bin/payload-agent.js"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "bin",
    "skills"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm build:types && pnpm build:swc",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --outDir dist --rootDir ./src",
    "clean": "rimraf {dist,*.tsbuildinfo}",
    "check": "biome check ./src",
    "check:fix": "biome check --write ./src",
    "format": "biome format --write ./src",
    "payload-agent": "tsx ./src/cli.ts"
  },
  "dependencies": {
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@swc-node/register": "1.10.9",
    "@swc/cli": "0.6.0",
    "@types/node": "22.19.9",
    "payload": "3.37.0",
    "rimraf": "3.0.2",
    "typescript": "5.7.3"
  },
  "peerDependencies": {
    "payload": "^3.0.0"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  },
  "publishConfig": {
    "bin": {
      "payload-agent": "./bin/payload-agent.js"
    },
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "keywords": [
    "payloadcms",
    "payload",
    "cms",
    "cli",
    "ai",
    "agent",
    "headless-cms"
  ]
}
